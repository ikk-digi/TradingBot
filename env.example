# ── Binance API (Futures Testnet or Mainnet) ─────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# true = ใช้ Testnet (แนะนำก่อนเริ่ม Live)
# false = ใช้เงินจริง ⚠️ ระวัง!
BINANCE_TESTNET=true

# ====================================================
# Trading Configuration
# ====================================================
SYMBOL=BTCUSDT
INTERVAL=1h       # 1m, 5m, 15m, 1h, 4h
LEVERAGE=5         # 1-125x (แนะนำ: 3-10x)
RISK_PCT=1.0       # % ของ balance ที่ยอมเสียต่อเทรด (แนะนำ: 0.5-2%)

# ====================================================
# Backtesting
# ====================================================
BACKTEST_DAYS=90
BACKTEST_BALANCE=1000
